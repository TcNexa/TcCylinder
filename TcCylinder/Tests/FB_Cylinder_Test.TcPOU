END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="testMoveToHP_SensorNotUsed_Ok" Id="{cae04e04-fcd3-06a6-1c88-7ef205971d01}">
      <Declaration><![CDATA[METHOD PROTECTED testMoveToHP_SensorNotUsed_Ok
VAR_INST
	_testTimeout		: Tc2_Standard.TON;
	_Cylinder 			: FB_Cylinder	(name		:= 'Cylinder',
										tag			:= 'C1',
										sensorTagHP	:= '',
										sensorTagWP	:= 'B2');
	_Response			: TcNexa_Components_TcProcess.FB_MethodResponse;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF TcUnit.TEST_ORDERED(TestName:= 'testMoveToHP_SensorNotUsed_Ok') THEN
	// Timeout if the movement is not executed right
	_testTimeout(IN:= TRUE, PT:= T#10S);
	// Cylinder call
	_Cylinder.Config.delayTimeAfterReachedHP:= T#1S;
	_Cylinder.FB_main();
	_Cylinder.moveToHP(Response:= _Response);
	// Wait result
	IF _testTimeout.Q OR _Cylinder.inHP OR NOT _Response.busy THEN
		AssertTrue(
			Condition	:= _Cylinder.inHP,
			Message		:= 'inHP not TRUE');
		AssertFalse(
			Condition	:= _Cylinder.inWP,
			Message		:= 'inWP not FALSE');
		AssertFalse(
			Condition	:= _Response.busy,
			Message		:= 'busy not FALSE');
		AssertFalse(
			Condition	:= _Response.error,
			Message		:= 'error not FALSE');
			
		TcUnit.TEST_FINISHED();
	END_IF
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="testMoveToHP_SensorReached_Ok" Id="{20c59df5-acc8-4cd6-8d73-fe0f6e62b740}">
      <Declaration><![CDATA[METHOD PROTECTED testMoveToHP_SensorReached_Ok
VAR_INST
	_testTimeout		: Tc2_Standard.TON;
	_Cylinder 			: FB_Cylinder	(name		:= 'Cylinder',
										tag			:= 'C1',
										sensorTagHP	:= 'B1',
										sensorTagWP	:= 'B2');
	_Response			: TcNexa_Components_TcProcess.FB_MethodResponse;
	_timerDelay			: Tc2_Standard.TON;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF TcUnit.TEST_ORDERED(TestName:= 'TestMoveToHP_SensorReached_Ok') THEN
	// Timeout if the movement is not executed right
	_testTimeout(IN:= TRUE, PT:= T#10S);
	_timerDelay(IN:= TRUE, PT:= T#1S);
	// Cylinder call
	_Cylinder.Config.delayTimeAfterReachedHP:= T#1S;	
	_Cylinder.FB_main();
	_Cylinder.moveToHP(Response:= _Response);
	TcUnit.WRITE_PROTECTED_BOOL(Ptr:= ADR(_Cylinder.sensorHP), Value:= _timerDelay.Q);
	// Wait result
	IF _testTimeout.Q OR _Cylinder.inHP OR NOT _Response.busy THEN
		AssertTrue(
			Condition	:= _Cylinder.inHP,
			Message		:= 'inHP not TRUE');
		AssertFalse(
			Condition	:= _Cylinder.inWP,
			Message		:= 'inWP not FALSE');
		AssertFalse(
			Condition	:= _Response.busy,
			Message		:= 'busy not FALSE');
		AssertFalse(
			Condition	:= _Response.error,
			Message		:= 'error not FALSE');
		AssertEquals_TIME(
			Expected	:= _timerDelay.ET + _Cylinder.Config.delayTimeAfterReachedHP + T#10MS,
			Actual		:= _testTimeout.ET,
			Message		:= 'delayTimeAfterReachedHP missmatch');
			
		TcUnit.TEST_FINISHED();
	END_IF
END_IF]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>