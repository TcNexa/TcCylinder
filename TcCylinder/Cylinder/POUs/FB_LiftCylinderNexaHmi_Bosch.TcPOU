    </Property>
    <Property Name="interlockMessageHP" Id="{bbc3c2f4-778a-01f7-393f-da4f30078d14}" FolderPath="Property\">
      <Declaration><![CDATA[PROPERTY interlockMessageHP : STRING(255)]]></Declaration>
      <Get Name="Get" Id="{d7f6817c-563e-0e2e-2929-d181239c617b}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[interlockMessageHP:= _interlockHPforOtherDevices;]]></ST>
        </Implementation>
      </Get>
    </Property>
