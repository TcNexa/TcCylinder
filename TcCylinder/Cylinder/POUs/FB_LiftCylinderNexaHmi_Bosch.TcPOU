END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[hostName:= _Hmi.hostName;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{abc1a50a-705c-0124-0374-77eee3c6b333}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
