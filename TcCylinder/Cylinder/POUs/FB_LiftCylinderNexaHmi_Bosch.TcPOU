      <Declaration><![CDATA[PROPERTY interlockMessageWP : STRING(255)]]></Declaration>
      <Get Name="Get" Id="{e512db67-e7bf-0c5d-37d2-925aadb1974e}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[interlockMessageWP:= _interlockWPforOtherDevices;]]></ST>
        </Implementation>
      </Get>
    </Property>
